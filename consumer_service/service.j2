[Unit]
Description=Lasair consumer service
After=network.target

[Service]
Type=simple
User={{ ansible_user_id }}
WorkingDirectory=/opt/consumer_service
ExecStart=/opt/consumer_service/venv/bin/python3 consumer_service.py --out={{out}} --group={{group_id}} --topic={{topic}}
Restart=on-failure

[Install]
WantedBy=multi-user.target